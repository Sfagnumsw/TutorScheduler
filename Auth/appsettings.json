{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NLog": {
    "targets": {
      "file": {
        "type": "File",
        "fileName": "D:\\Other\\TutorSchedulerLogs\\nlog-all-${shortdate}.log",
        "layout": "${longdate}|${level}|${logger}|${message}"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Trace",
        "writeTo": "file"
      },
      {
        "logger": "Microsoft.*",
        "finalMinLevel": "Warn"
      }
    ]
  },
  "AllowedHosts": "*"
}